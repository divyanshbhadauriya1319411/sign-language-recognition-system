# =========================================================
# SignBridge ISL Enterprise - Environment Configuration
# =========================================================

# --- General System ---
PROJECT_NAME="SignBridge ISL Enterprise Platform"
ENVIRONMENT="development"  # development | staging | production
DEBUG=True
LOG_LEVEL="INFO"
SECRET_KEY="09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000"]'

# --- Primary Database (MongoDB Engine) ---
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DB_NAME="signbridge_enterprise_db"
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secretpassword

# --- Redis (Cache, Celery Broker & Token Revocation Pool) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# --- AI Microservice Configuration ---
AI_SERVICE_URL="http://localhost:8001"
AI_WEBSOCKET_URL="ws://localhost:8001/ai/v1/stream"
AI_MODEL_PATH="/app/models/isl_gesture_model_v2.pt"
AI_VOCABULARY_PATH="/app/models/vocabulary.json"
TEMPORAL_BUFFER_SIZE=30
CONFIDENCE_THRESHOLD=0.75
MIN_HAND_DETECTION_CONFIDENCE=0.7
MIN_HAND_TRACKING_CONFIDENCE=0.5
INFERENCE_ENGINE="pytorch" # pytorch | tensorflow | cpu_fallback

# --- Object Storage Abstraction Layer (S3 / Azure Blob / Cloudinary / Local) ---
STORAGE_PROVIDER="local"  # local | s3 | azure | cloudinary
LOCAL_STORAGE_PATH="./storage"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_STORAGE_BUCKET_NAME="signbridge-enterprise-assets"
AWS_S3_REGION_NAME="us-east-1"
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_CONTAINER_NAME="signbridge-assets"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Speech Provider Abstraction Layer (Google / Coqui / Azure / Amazon Polly) ---
SPEECH_PROVIDER="google"  # google | coqui | azure | polly
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="eastus"
POLLY_VOICE_ID="Aditi"

# --- Frontend Vite & React SPA Configuration ---
VITE_API_URL="http://localhost:8000/api/v1"
VITE_AI_WS_URL="ws://localhost:8001/ai/v1/stream"
VITE_AI_REST_URL="http://localhost:8001/ai/v1"
VITE_APP_NAME="SignBridge ISL Enterprise"

# --- Legacy Aliases for Compatibility ---
